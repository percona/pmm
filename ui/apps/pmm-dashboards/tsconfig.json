{
  "extends": "./.config/tsconfig.json",
  "include": ["src", "types"],
  "exclude": ["**/__mocks__/**", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
  "compilerOptions": {
    "rootDir": "./src",
    "baseUrl": "./src",
    "typeRoots": ["./node_modules/@types"],
    "types": ["jest", "mocha", "grafana"],
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
