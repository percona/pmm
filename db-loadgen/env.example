# Example environment variables for db-loadgen

# MySQL DSN (Data Source Name)
MYSQL_DSN=testuser:testpass@tcp(localhost:3306)/testdb

# PostgreSQL DSN
POSTGRES_DSN=postgres://testuser:testpass@localhost:5432/testdb?sslmode=disable

# MongoDB DSN
MONGO_DSN=mongodb://testuser:testpass@localhost:27017/testdb

# Load generation settings
DURATION=60s
WORKERS=5 