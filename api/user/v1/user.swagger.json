          "type": "integer",
          "format": "int64",
          "title": "User ID"
        },
        "product_tour_completed": {
          "type": "boolean",
          "title": "Product Tour"
        },
        "alerting_tour_completed": {
          "type": "boolean",
          "title": "Alerting Tour"
        },
        "snoozed_pmm_version": {
          "type": "string",
          "title": "Snooze update alert for a PMM version"
        },
        "snoozed_at": {
          "type": "string",
          "format": "date-time",
          "title": "Timestamp of last snooze"
        },
        "snooze_count": {
          "type": "integer",
          "format": "int64",
          "title": "Number of times the update was snoozed"
        }
