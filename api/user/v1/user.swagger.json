        },
        "product_tour_completed": {
          "type": "boolean",
          "title": "Product Tour"
        },
        "alerting_tour_completed": {
          "type": "boolean",
          "title": "Alerting Tour"
        },
        "snoozed_pmm_version": {
          "type": "string",
