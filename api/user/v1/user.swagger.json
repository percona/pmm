      "type": "object",
      "properties": {
        "product_tour_completed": {
          "type": "boolean",
          "x-nullable": true,
          "title": "Product Tour"
        },
        "alerting_tour_completed": {
          "type": "boolean",
          "x-nullable": true,
          "title": "Alerting Tour"
        },
