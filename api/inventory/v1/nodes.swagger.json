              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "node_id",
            "description": "Unique randomly generated instance identifier.",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "force",
            "description": "Remove node with all dependencies.",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "NodesService"
        ]
      }
    }
