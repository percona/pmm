.DEFAULT_GOAL := help

# --- Swagger-related variables ---------------------------------------------------------
SWAGGER_UI_VERSION ?= latest

# --- API Specs-related variables  -------------------------------------------------------
# List of public API specs.
# Add new API dir here if it SHALL appear in production spec (i.e. swagger.json).
PUBLIC_SPECS := \
	server/v1 \
	user/v1 \
	inventory/v1 \
	management/v1 \
	actions/v1 \
	alerting/v1 \
	advisors/v1 \
	backup/v1 \
	qan/v1 \
	realtimeanalytics/v1 \
	ha/v1beta1

# List of development API specs.
# Add new API dir here if it SHALL appear in development spec (i.e. swagger-dev.json).
DEV_SPECS := \
	server/v1 \
	user/v1 \
	inventory/v1 \
	management/v1 \
	actions/v1 \
	alerting/v1 \
	advisors/v1 \
	backup/v1 \
	dump/v1beta1 \
	accesscontrol/v1beta1 \
	qan/v1 \
	realtimeanalytics/v1 \
	ha/v1beta1

# List of private API specs.
# Add new API dir here if it SHALL NOT appear in any swagger files but still needs 
# to be generated (for private usage like local agent).
PRIVATE_SPECS := \
	agentlocal/v1

# Add new API dir here if swagger spec generation is not require but formatting 
# for generated Go files is still needs to be (like extensions or common includes).
ADDITIONAL_FORMAT_SPECS := \
	agent/v1 \
	agent/pb \
	common \
	extensions

# --- Generation and Formatting --------------------------------------------------------	
ALL_SPECS := $(sort $(PUBLIC_SPECS) $(DEV_SPECS) $(PRIVATE_SPECS))

# Pre-calculate JSON lists for swagger generation.
# $(notdir ...) behaves like 'basename' to get 'v1' from 'server/v1'.
PUBLIC_JSON_LIST := $(foreach API,$(PUBLIC_SPECS),$(API)/json/$(notdir $(API)).json)
DEV_JSON_LIST    := $(foreach API,$(DEV_SPECS),$(API)/json/$(notdir $(API)).json)

# List of API specs dirs for generated Go files formatting.
FORMAT_SPECS     := $(sort $(ALL_SPECS) $(ADDITIONAL_FORMAT_SPECS))
# ------------------------------------------------------------------------------------------

.PHONY: help gen _gen format clean-swagger update-swagger clean  descriptors

help: 	## Display this help message
	@echo "Please use \`make <target>\`, where <target> is one of the following:"
	@awk 'BEGIN {FS = ":.*## "}; /^[a-zA-Z0-9-]+:.*## / {printf "  %-23s%s\n", $$1, $$2}' $(MAKEFILE_LIST)

gen: clean	_gen format 	## Generate PMM API (includes formatting)
	$(MAKE) clean-swagger

_gen:
	@echo "Generating API files..."
	# generated by descriptors target
	go tool buf breaking --against descriptor.bin $(CURDIR)
	go tool buf generate -v $(CURDIR)

	@for API in $(ALL_SPECS); do \
		set -x ; \
		go tool swagger mixin $$API/json/header.json $$API/*.swagger.json --output=$$API/json/$$(basename $$API).json --keep-spec-order; \
		go tool swagger flatten --with-flatten=expand --with-flatten=remove-unused $$API/json/$$(basename $$API).json --output=$$API/json/$$(basename $$API).json ; \
		go tool swagger validate $$API/json/$$(basename $$API).json ; \
		go tool swagger generate client --with-flatten=expand --with-flatten=remove-unused --spec=$$API/json/$$(basename $$API).json --target=$$API/json \
			--additional-initialism=aws \
			--additional-initialism=db \
			--additional-initialism=ok \
			--additional-initialism=pmm \
			--additional-initialism=psmdb \
			--additional-initialism=pxc \
			--additional-initialism=pt \
			--additional-initialism=qan \
			--additional-initialism=realtimeanalytics \
			--additional-initialism=rds \
			--additional-initialism=sql \
			--additional-initialism=ha ; \
	done

	# generate public API spec, omit agentlocal (always private),
	# as well as a number of protos that are in beta (not v1 yet, they all go to a similar call below)
	go tool swagger mixin --output=swagger/swagger.json \
		swagger/header.json \
		$(PUBLIC_JSON_LIST)
	go tool swagger validate swagger/swagger.json

	# generate API spec with all PMM Server APIs (omit agentlocal)
	go tool swagger mixin --output=swagger/swagger-dev.json \
		swagger/header-dev.json \
		$(DEV_JSON_LIST)
	go tool swagger validate swagger/swagger-dev.json

# NOTE: For some reason one `gofumpt` is not enough
format: 	## Format API definitions
	@echo "Formatting API files..."
	go tool buf format -w $(CURDIR)
	@for API in $(FORMAT_SPECS); do \
		echo "Running formatting for $$API"; \
		FILES=$$(find $$API -type f -name '*.go'); \
		if [ -n "$$FILES" ]; then \
			set -x ; \
			go tool gofumpt -w $$FILES; \
			go tool goimports -local github.com/percona/pmm -w $$FILES; \
			go tool gci write --section Standard --section Default --section "Prefix(github.com/percona/pmm)" $$FILES; \
			go tool gofumpt -w $$FILES; \
			{ set +x; } 2>/dev/null; \
		fi; \
	done

clean-swagger:
	@echo "Cleaning up Swagger files..."
	find . -name '*.swagger.json' -print -delete


ifeq ($(shell test "${SWAGGER_UI_VERSION}" = "latest" && echo 1 || echo 0), 1)
get_swagger_version:
override SWAGGER_UI_VERSION = $(shell curl --silent --head https://github.com/swagger-api/swagger-ui/releases/latest | grep -E '^[lL]ocation' | sed 's;^.*/;;')
else
get_swagger_version:
endif

update-swagger: get_swagger_version               ## Update Swagger UI in swagger, use `SWAGGER_UI_VERSION=xxx make update-swagger` to choose a version other than latest
	curl --output /tmp/swagger.tar.gz -sSfL "https://github.com/swagger-api/swagger-ui/archive/refs/tags/${SWAGGER_UI_VERSION}.tar.gz"
	tar xf /tmp/swagger.tar.gz --transform 's;swagger-ui-.*/dist/;swagger/;g'
	rm -f swagger/.npmrc
	sed -i 's/url: ".*"/url: "\/swagger.json",\n    validatorUrl: "none"/' swagger/swagger-initializer.js

clean: clean-swagger  ## Remove generated files
	@echo "Cleaning up generated Go files..."
	find . -name '*.pb.go' -print -delete
	find . -name '*.pb.gw.go' -print -delete
	find . -name '*.validate.go' -print -delete

	for API in $(ALL_SPECS); do \
		rm -fr $$API/json/client $$API/json/models $$API/json/$$(basename $$API).json ; \
	done
	rm -f swagger/swagger.json swagger/swagger-dev.json

descriptors:          ## Update API compatibility descriptors
	go tool buf build -o descriptor.bin --as-file-descriptor-set $(CURDIR)

check: ## Run required checks and linters
	go tool buf lint -v $(CURDIR)

test: ## Run tests
	go test -count=1 -race -p 1 -v ./...