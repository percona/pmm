FROM redhat/ubi9 AS builder

RUN dnf install -y shadow-utils jq tar https://repo.percona.com/yum/percona-release-latest.noarch.rpm \
    && percona-release enable ps-80 \
    && dnf install -y percona-server-client

# Install required dependencies
RUN dnf install -y \
    perl-core \
    perl-DBD-MySQL \
    perl-DBI \
    perl-Digest-MD5 \
    perl-English \
    perl-FindBin \
    perl-IO-Socket-SSL \
    perl-Sys-Hostname \
    perl-TermReadKey \
    perl-Time-HiRes \
    perl-sigtrap \
    && rm -rf /var/cache/*

RUN groupadd -g 1002 pmm-agent && \
    useradd -u 1002 -g pmm-agent -s /sbin/nologin \
            -d /usr/local/percona/pmm \
            -c "PMM Client User" pmm-agent

ADD pmm-client.tar.gz /tmp/

RUN PMM_USER=pmm-agent PMM_GROUP=root /tmp/pmm-client*/install_tarball

FROM redhat/ubi9-micro AS micro

FROM scratch

COPY --from=micro / /

COPY LICENSE /licenses/
COPY --from=builder --chown=0:0 /etc/passwd /etc/group /etc/

# Install tools and perl
COPY --from=builder --chown=0:0 \
  /usr/bin/jq \
  /usr/bin/tar \
  /usr/bin/curl \
  /usr/bin/sed \
  /usr/bin/grep \
  /usr/bin/awk \
  /usr/bin/mysql* \
  /usr/bin/perl* \
  /usr/bin/

COPY --from=builder --chown=0:0 \
  /usr/lib64/libjq.so.1 \
  /usr/lib64/libonig.so.5 \
  /usr/lib64/*perl* \
  /usr/lib64/libcrypt.so* \
  /usr/lib64/libstdc++.so* \
  /usr/lib64/libreadline.so* \
  /usr/lib64/libkeyutils.so* \
  /usr/lib64/libz.so* \
  /usr/lib64/libkrb5support.so* \
  /usr/lib64/libkrb5.so* \
  /usr/lib64/libk5crypto.so* \
  /usr/lib64/libgssapi_krb5.so* \
  /usr/lib64/libcom_err.so* \
  /usr/lib64/libssl.so* \
  /usr/lib64/libcrypto.so* \
  /usr/lib64/libcurl.so* \
  /usr/lib64/libnghttp2.so* \
  /usr/lib64/libresolv.so* \
  /lib64/libpcre.so.1 \
  /lib64/libsigsegv.so.2 \
  /lib64/libgmp.so.10 \
  /lib64/libmpfr.so.6 \
  /usr/lib64/

COPY --from=builder --chown=0:0 /usr/share/perl5 /usr/share/perl5
COPY --from=builder --chown=0:0 /etc/ld.so.conf.d/mysql-*.conf /etc/ld.so.conf.d

# Install pmm-client
RUN install -d -o pmm-agent -g pmm-agent -m 0775 /usr/local/percona/pmm
COPY --from=builder /usr/local/percona/pmm /usr/local/percona/pmm/

ARG VERSION
ARG BUILD_DATE
ARG RELEASE

# Satisfy as well https://docs.redhat.com/en-us/documentation/red_hat_software_certification/2026/pdf/red_hat_openshift_software_certification_policy_guide/Red_Hat_Software_Certification-2026-Red_Hat_OpenShift_Software_Certification_Policy_Guide-en-US.pdf
LABEL org.opencontainers.image.created=${BUILD_DATE} \
    org.opencontainers.image.licenses=Apache-2.0 \
    org.opencontainers.image.title="Percona Monitoring and Management Client" \
    org.opencontainers.image.vendor="Percona, LLC" \
    org.opencontainers.image.version=${VERSION} \
    org.opencontainers.image.description="The client image for Percona Monitoring and Management" \
    org.opencontainers.image.url="https://docs.percona.com/percona-monitoring-and-management" \
    name="percona/pmm-client" \
    summary="Percona Monitoring and Management Client" \
    description="The client image for Percona Monitoring and Management" \
    vendor="Percona, LLC" \
    maintainer="Percona, LLC" \
    version=${VERSION} \
    release=${RELEASE}

USER pmm-agent
WORKDIR /usr/local/percona/pmm/
ENV PATH=/usr/local/percona/pmm/bin/:$PATH

ENTRYPOINT ["/usr/local/percona/pmm/bin/pmm-agent-entrypoint"]
