#!/usr/bin/env bash
# check-build-cache: Determine whether a component needs rebuilding.
#
# Resolves the current ref to a full commit hash (via the local bare repo)
# and compares it against the hash stored in a stamp file from a previous build.
# If both match AND the output directory is non-empty, the build can be skipped.
#
# Usage:
#   check-build-cache <component> <ref> <bare-repo-path> <output-dir> <stamp-dir>
#
# Arguments:
#   component     Component name             (e.g. "pmm-dump", "node_exporter")
#   ref           Branch, tag, or commit hash (e.g. value of GRAFANA_REF)
#   bare-repo     Path to the local bare repo (e.g. .cache/repos/grafana.git)
#   output-dir    Component output directory  (e.g. output/server/grafana-ui)
#   stamp-dir     Directory for stamp files   (e.g. .cache/stamps)
#
# Exit codes:
#   0 — build is needed  (cache miss, missing output, or changed hash)
#   1 — build can be skipped (hash unchanged, output already present)

set -uo pipefail

COMPONENT="$1"
REF="$2"
BARE_REPO="$3"
OUTPUT_DIR="$4"
STAMP_DIR="$5"

STAMP_FILE="${STAMP_DIR}/${COMPONENT}.hash"

# Always build if output directory is missing or empty
if [ ! -d "$OUTPUT_DIR" ] || [ -z "$(ls -A "$OUTPUT_DIR" 2>/dev/null)" ]; then
    echo "[$COMPONENT] Output dir missing or empty — building." >&2
    exit 0
fi

# Always build if there is no previous stamp file
if [ ! -f "$STAMP_FILE" ]; then
    echo "[$COMPONENT] No previous build stamp — building." >&2
    exit 0
fi

# Resolve the ref to a full commit hash using the local bare repo.
# When REF is empty (not set in .env), fall back to HEAD of the bare repo —
# consistent with what `git checkout` (no argument) does in the build containers.
CURRENT_HASH=""
if [ -d "$BARE_REPO" ]; then
    if [ -n "$REF" ]; then
        CURRENT_HASH=$(git -C "$BARE_REPO" rev-parse "${REF}^{commit}" 2>/dev/null || echo "")
    fi
    if [ -z "$CURRENT_HASH" ]; then
        CURRENT_HASH=$(git -C "$BARE_REPO" rev-parse HEAD 2>/dev/null || echo "")
    fi
else
    CURRENT_HASH="$REF"
fi

if [ -z "$CURRENT_HASH" ]; then
    echo "[$COMPONENT] Could not resolve ref '${REF}' — building." >&2
    exit 0
fi

# Read the cached hash from the stamp file
CACHED_HASH=$(tr -d '[:space:]' < "$STAMP_FILE" 2>/dev/null || echo "")

if [ -n "$CACHED_HASH" ] && [ "$CURRENT_HASH" = "$CACHED_HASH" ]; then
    echo "[$COMPONENT] Commit hash unchanged (${CURRENT_HASH:0:12}) — skipping build." >&2
    exit 1
fi

echo "[$COMPONENT] Hash changed (current=${CURRENT_HASH:0:12}, cached=${CACHED_HASH:0:12}) — building." >&2
exit 0
