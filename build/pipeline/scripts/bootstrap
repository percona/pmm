#!/usr/bin/env bash
# bootstrap — zero-to-build setup for the PMM build pipeline.
#
# Checks prerequisites, starts Minio, installs mc, configures cache,
# and optionally kicks off a build.
#
# Usage: bootstrap [--target client|server|all] [--migrate] [--skip-cache] [--help]

set -euo pipefail

# When piped (curl | bash), BASH_SOURCE[0] is empty — create ~/build.
if [ -n "${BASH_SOURCE[0]:-}" ] && [ -f "${BASH_SOURCE[0]}" ]; then
    BASH_DIR="$(realpath "$(dirname "${BASH_SOURCE[0]}")")"
else
    BASH_DIR="${HOME}/build"
    if [ -d "${BASH_DIR}" ] && [ -n "$(ls -A "${BASH_DIR}")" ]; then
        echo "Error: ${BASH_DIR} already exists and is not empty. Remove it or run bootstrap from that directory." >&2
        exit 1
    fi
    mkdir -p "${BASH_DIR}"
fi
PIPELINE_DIR="${BASH_DIR}"
SCRIPT_DIR="${PIPELINE_DIR}/scripts"

# Defaults
BUILD_TARGET=""
RUN_MIGRATE=false
SKIP_CACHE=false
GIT_REF="v3"
TOTAL_STEPS=8

PMM_REPO_URL="https://github.com/percona/pmm.git"
BUILD_ROOT="$(dirname "${PIPELINE_DIR}")"

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Set up the PMM build pipeline from scratch: check prerequisites, start Minio,
install mc, populate the bare-repo cache, and optionally kick off a build.

Options:
  --target <client|server|all>   Build target after setup (default: skip build)
  --migrate                      Run migrate-from-submodules to populate .env
  --ref <branch|tag|sha>         Git ref to download build files from (default: v3)
  --skip-cache                   Skip cache population and upload
  --help                         Show this help

Examples:
  $(basename "$0")                          # setup only
  $(basename "$0") --migrate                # setup + populate .env from pmm-submodules
  $(basename "$0") --target client          # setup + build client
  $(basename "$0") --skip-cache --target server  # setup (no cache) + build server
EOF
    exit 0
}

# ── Argument parsing ────────────────────────────────────────────────────────

while [ $# -gt 0 ]; do
    case "$1" in
        --target)
            BUILD_TARGET="$2"
            case "${BUILD_TARGET}" in
                client|server|all) ;;
                *) echo "Error: --target must be one of: client, server, all" >&2; exit 1 ;;
            esac
            shift 2
            ;;
        --ref)
            GIT_REF="$2"; shift 2
            ;;
        --migrate)   RUN_MIGRATE=true; shift ;;
        --skip-cache) SKIP_CACHE=true; shift ;;
        --help)      usage ;;
        *) echo "Unknown argument: $1" >&2; exit 1 ;;
    esac
done

# ── Helpers ─────────────────────────────────────────────────────────────────

log_step() {
    local n="$1" msg="$2"
    echo ""
    echo "==> [${n}/${TOTAL_STEPS}] ${msg}"
}

log_info() { echo "$(date -Iseconds)    INFO: $*"; }
log_warn() { echo "$(date -Iseconds)    WARN: $*"; }
log_err()  { echo "$(date -Iseconds)    ERROR: $*" >&2; }

# ── Step 1: Prerequisites ──────────────────────────────────────────────────

check_prerequisites() {
    log_step 1 "Checking prerequisites"

    if ! command -v docker >/dev/null 2>&1; then
        log_err "docker is not installed"
        echo "    Install Docker: https://docs.docker.com/get-docker/"
        exit 1
    fi
    log_info "docker found ($(docker --version))"

    if ! command -v git >/dev/null 2>&1; then
        log_err "git is not installed"
        exit 1
    fi
    log_info "git found ($(git --version))"

    if ! docker info >/dev/null 2>&1; then
        log_err "Docker daemon is not running"
        echo "    Start Docker Desktop (macOS) or the docker service (Linux)"
        exit 1
    fi
    log_info "Docker daemon is running"
}

# ── Step 2: Download build files ───────────────────────────────────────────

download_build_files() {
    log_step 2 "Downloading build files"

    # If Dockerfile.builder exists, assume all build files are present
    # (either from a full repo clone or a previous bootstrap run).
    if [ -f "${PIPELINE_DIR}/Dockerfile.builder" ]; then
        log_info "Build files already present"
        return
    fi

    log_info "Fetching build/ directory from ${PMM_REPO_URL} (ref: ${GIT_REF})..."
    local tmpdir
    tmpdir="$(mktemp -d)"
    # shellcheck disable=SC2064
    trap "rm -rf '${tmpdir}'" EXIT

    git clone --depth 1 --branch "${GIT_REF}" --sparse --filter=blob:none \
        "${PMM_REPO_URL}" "${tmpdir}/pmm"
    git -C "${tmpdir}/pmm" sparse-checkout set build/

    local src="${tmpdir}/pmm/build"

    # Copy pipeline files that are missing (Dockerfiles, Makefile, .env.example).
    for f in Makefile Dockerfile.builder Dockerfile.client Dockerfile.server \
             Dockerfile.server.dockerignore .env.example; do
        if [ ! -f "${PIPELINE_DIR}/${f}" ]; then
            cp "${src}/pipeline/${f}" "${PIPELINE_DIR}/${f}"
            log_info "Installed ${f}"
        fi
    done

    # Copy build scripts that are missing.
    mkdir -p "${SCRIPT_DIR}"
    for f in build-component build-client-docker package-tarball \
             generate-version-json check-ui-cache migrate-from-submodules; do
        if [ ! -f "${SCRIPT_DIR}/${f}" ]; then
            cp "${src}/pipeline/scripts/${f}" "${SCRIPT_DIR}/${f}"
            chmod +x "${SCRIPT_DIR}/${f}"
            log_info "Installed scripts/${f}"
        fi
    done

    # Copy sibling directories needed by the build (ansible, docker, packages, scripts).
    # These live in BUILD_ROOT (parent of PIPELINE_DIR).
    for dir in ansible docker packages scripts; do
        if [ ! -d "${BUILD_ROOT}/${dir}" ]; then
            cp -r "${src}/${dir}" "${BUILD_ROOT}/${dir}"
            log_info "Installed ${dir}/"
        fi
    done

    rm -rf "${tmpdir}"
    trap - EXIT
    log_info "Build files downloaded"
}

# ── Step 3: .env setup ─────────────────────────────────────────────────────

setup_env() {
    log_step 3 "Setting up .env"

    if [ -f "${PIPELINE_DIR}/.env" ]; then
        log_info ".env already exists"
    else
        if [ ! -f "${PIPELINE_DIR}/.env.example" ]; then
            log_err ".env.example not found in ${PIPELINE_DIR}"
            exit 1
        fi
        cp "${PIPELINE_DIR}/.env.example" "${PIPELINE_DIR}/.env"
        log_info "Created .env from .env.example"

        # Replace placeholder Minio credentials with defaults
        sed -i.bak 's/MINIO_ACCESS_KEY=<ACCESS_KEY>/MINIO_ACCESS_KEY=minioadmin/' "${PIPELINE_DIR}/.env"
        sed -i.bak 's/MINIO_SECRET_KEY=<SECRET_KEY>/MINIO_SECRET_KEY=minioadmin/' "${PIPELINE_DIR}/.env"
        rm -f "${PIPELINE_DIR}/.env.bak"
        log_info "Set default Minio credentials (minioadmin/minioadmin)"
    fi

    if [ "${RUN_MIGRATE}" = true ]; then
        echo "    Running migrate-from-submodules..."
        "${SCRIPT_DIR}/migrate-from-submodules"
        log_info "Migration complete"
    fi

    # Source .env
    set -o allexport
    # shellcheck source=/dev/null
    source "${PIPELINE_DIR}/.env"
    set +o allexport

    MINIO_ACCESS_KEY="${MINIO_ACCESS_KEY:-minioadmin}"
    MINIO_SECRET_KEY="${MINIO_SECRET_KEY:-minioadmin}"
    MINIO_BUCKET="${MINIO_BUCKET:-cache}"

    # Warn if REFs are empty (common when .env was just copied from .env.example)
    if [ -z "${PMM_VERSION:-}" ]; then
        log_warn "PMM_VERSION is empty in .env"
        if [ "${RUN_MIGRATE}" = false ]; then
            echo "    Run with --migrate to populate from pmm-submodules, or edit .env manually"
        fi
    fi
}

# ── Step 4: Start Minio ────────────────────────────────────────────────────

start_minio() {
    log_step 4 "Starting Minio..."

    local state
    state="$(docker inspect --format='{{.State.Running}}' minio 2>/dev/null || echo "missing")"

    case "${state}" in
        true)
            log_info "Minio container is already running"
            ;;
        false)
            echo "    Minio container exists but is stopped, restarting..."
            docker start minio >/dev/null
            log_info "Minio container restarted"
            ;;
        *)
            echo "    Creating Minio container..."
            docker run -d --name minio \
                -p 9000:9000 -p 9001:9001 \
                -e MINIO_ROOT_USER="${MINIO_ACCESS_KEY}" \
                -e MINIO_ROOT_PASSWORD="${MINIO_SECRET_KEY}" \
                -v minio-data:/data \
                minio/minio server /data --console-address ":9001" >/dev/null
            log_info "Minio container created"
            ;;
    esac

    # Wait for Minio to become healthy
    echo "    Waiting for Minio to be ready..."
    local attempts=0
    while [ ${attempts} -lt 15 ]; do
        if curl -sf http://localhost:9000/minio/health/live >/dev/null 2>&1; then
            log_info "Minio is healthy"
            return
        fi
        attempts=$((attempts + 1))
        sleep 1
    done
    log_err "Minio did not become healthy within 15 seconds"
    echo "    Check: docker logs minio"
    exit 1
}

# ── Step 5: Install mc ─────────────────────────────────────────────────────

install_mc() {
    log_step 5 "Installing mc (Minio client)..."

    # Check if MinIO's mc is already available
    if command -v mc >/dev/null 2>&1 && mc --version 2>&1 | grep -q "mc version"; then
        log_info "mc is already installed ($(mc --version 2>&1 | head -1))"
        return
    fi

    local os arch
    os="$(uname -s)"
    arch="$(uname -m)"

    case "${arch}" in
        x86_64)        arch="amd64" ;;
        aarch64|arm64) arch="arm64" ;;
        *) log_err "Unsupported architecture: ${arch}"; exit 1 ;;
    esac

    case "${os}" in
        Darwin)
            if command -v brew >/dev/null 2>&1; then
                echo "    Installing mc via Homebrew..."
                brew install minio/stable/mc
                log_info "mc installed via Homebrew"
                return
            fi
            os="darwin"
            ;;
        Linux)
            os="linux"
            ;;
        *)
            log_err "Unsupported OS: ${os}"
            exit 1
            ;;
    esac

    # Direct binary download
    local mc_url="https://dl.min.io/client/mc/release/${os}-${arch}/mc"
    local mc_dir="${HOME}/.local/bin"
    local mc_path="${mc_dir}/mc"

    echo "    Downloading mc from ${mc_url}..."
    mkdir -p "${mc_dir}"
    curl -fsSL "${mc_url}" -o "${mc_path}"
    chmod +x "${mc_path}"
    log_info "mc installed to ${mc_path}"

    # Ensure it's on PATH for this session
    if ! echo "${PATH}" | tr ':' '\n' | grep -qx "${mc_dir}"; then
        export PATH="${mc_dir}:${PATH}"
        log_warn "${mc_dir} is not in your PATH"
        echo "    Add it to your shell profile: export PATH=\"\${HOME}/.local/bin:\${PATH}\""
    fi
}

# ── Step 6: Configure mc alias and bucket ───────────────────────────────────

configure_mc_alias() {
    log_step 6 "Configuring mc alias and bucket"

    mc alias set pmm "http://localhost:9000" "${MINIO_ACCESS_KEY}" "${MINIO_SECRET_KEY}" >/dev/null
    log_info "mc alias 'pmm' configured"

    mc mb --ignore-existing "pmm/${MINIO_BUCKET}" >/dev/null 2>&1
    log_info "Bucket '${MINIO_BUCKET}' is ready"
}

# ── Step 7: Populate cache ──────────────────────────────────────────────────

populate_cache() {
    if [ "${SKIP_CACHE}" = true ]; then
        log_step 7 "Populating repository cache (skipped: --skip-cache)"
        return
    fi

    log_step 7 "Populating repository cache"
    echo "    This clones 14 bare repos from upstream (first run may take a while)..."
    make -C "${PIPELINE_DIR}" populate-cache
}

# ── Step 8: Upload cache to Minio ──────────────────────────────────────────

upload_cache() {
    if [ "${SKIP_CACHE}" = true ]; then
        log_step 8 "Uploading cache to Minio (skipped: --skip-cache)"
        return
    fi

    log_step 8 "Uploading cache to Minio"
    local cache_dir="${PIPELINE_DIR}/.cache/repos"
    if [ ! -d "${cache_dir}" ]; then
        log_warn "No cache directory found at ${cache_dir}, nothing to upload"
        return
    fi
    # shellcheck disable=SC2012
    log_info "Uploading $(ls "${cache_dir}" | wc -l | tr -d ' ') repos to pmm/${MINIO_BUCKET}/repos..."
    mc mirror --overwrite "${cache_dir}" "pmm/${MINIO_BUCKET}/repos"
    log_info "Cache uploaded to Minio"
}

# ── Optional: Build ────────────────────────────────────────────────────────

run_build() {
    if [ -z "${BUILD_TARGET}" ]; then
        return
    fi

    echo ""
    echo "==> Starting build: ${BUILD_TARGET}"
    make -C "${PIPELINE_DIR}" "build-${BUILD_TARGET}"
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    echo "PMM Build Pipeline Bootstrap"
    echo "============================"

    check_prerequisites
    download_build_files
    setup_env
    start_minio
    install_mc
    configure_mc_alias
    populate_cache
    upload_cache
    run_build

    echo ""
    echo "Bootstrap complete!"
    echo "You can now run builds with:"
    echo "  cd ${PIPELINE_DIR} && make client   # build PMM Client"
    echo "  cd ${PIPELINE_DIR} && make server   # build PMM Server"
    echo "  cd ${PIPELINE_DIR} && make all      # build everything"
}

main "$@"
