{
  "variables": {
    "single_disk": "false",
    "pmm_server_image_name": "docker.io/perconalab/pmm-server:3-dev-latest",
    "watchtower_image_name": "docker.io/perconalab/watchtower:dev-latest"
  },
  "builders": [
    {
      "type": "amazon-ebs",
      "ami_name": "PMM Server [{{isotime \"2006-01-02 1504\"}}]",
      "instance_type": "c4.xlarge",
      "launch_block_device_mappings": [
        {
          "delete_on_termination": true,
          "device_name": "/dev/sda1",
          "volume_size": 20,
          "volume_type": "gp3"
        },
        {
          "delete_on_termination": false,
          "device_name": "/dev/sdb",
          "volume_size": 100,
          "volume_type": "gp3"
        }
      ],
      "region": "us-east-1",
      "security_group_id": "sg-688c2b1c",
      "source_ami": "ami-0da806cbfc9e67dbb",
      "ssh_pty": "true",
      "ena_support": "true",
      "ssh_username": "ec2-user",
      "subnet_id": "subnet-ee06e8e1",
      "run_tags": {
        "iit-billing-tag": "pmm-ami"
      },
      "run_volume_tags": {
        "iit-billing-tag": "pmm-ami"
      },
      "ssh_clear_authorized_keys": "true"
    }
  ],
  "provisioners": [
    {
      "type": "shell",
      "inline": [
        "sudo dnf -y update",
        "sudo dnf install -y rsync jq podman",
        "sudo dnf -y install epel-release",
        "sudo dnf -y install ansible-core",
        "sudo dnf -y install ansible-collection-community-general ansible-collection-ansible-posix"
      ]
    },
    {
      "type": "ansible-local",
      "playbook_file": "packer/ansible/pmm.yml",
      "command": "PYTHONUNBUFFERED=1 ansible-playbook",
      "extra_arguments": [
        "-vvv",
        "-u root",
        "--extra-vars",
        "\"pmm_server_image_name='{{ user `pmm_server_image_name` }}' watchtower_image_name='{{ user `watchtower_image_name` }}'\""
      ],
      "role_paths": [
        "packer/ansible/roles/lvm-init",
        "packer/ansible/roles/cloud-node",
        "packer/ansible/roles/podman-setup",
        "packer/ansible/roles/ami"
      ]
    }
  ],
  "post-processors": [
    [
      {
        "type": "manifest",
        "only": ["amazon-ebs"],
        "output": "manifest.json",
        "strip_path": true
      }
    ]
  ]
}
